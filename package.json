{
  "name": "thestudentagent.ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node --env-file=.env.local --import tsx tests/e2e/lifecycle.e2e.ts",
